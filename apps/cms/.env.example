HOST=0.0.0.0
PORT=1337
APP_KEYS="toBeModified1,toBeModified2"
API_TOKEN_SALT=tobemodified
ADMIN_JWT_SECRET=tobemodified
TRANSFER_TOKEN_SALT=tobemodified
JWT_SECRET=tobemodified
ENCRYPTION_KEY=tobemodified

# S3 media upload (aws-s3 provider). Leave AWS_BUCKET blank to keep local-disk uploads.
AWS_ACCESS_KEY_ID=
AWS_ACCESS_SECRET=
AWS_REGION=eu-central-1
AWS_BUCKET=
# Leave AWS_ACL empty for modern buckets (Object Ownership = "Bucket owner
# enforced", AWS default since 2023) — they reject ACLs, so grant public read
# via a bucket policy instead. Set to public-read only on buckets that allow ACLs.
AWS_ACL=
