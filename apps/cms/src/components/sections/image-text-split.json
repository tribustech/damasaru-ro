{
  "collectionName": "components_sections_image_text_splits",
  "info": {
    "displayName": "Image + Text Split",
    "icon": "picture"
  },
  "options": {},
  "attributes": {
    "eyebrow": { "type": "string" },
    "heading": { "type": "string", "required": true },
    "headingItalic": { "type": "string" },
    "body": { "type": "richtext" },
    "image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "imageCaption": { "type": "text" },
    "imagePosition": {
      "type": "enumeration",
      "enum": ["left", "right"],
      "default": "right"
    },
    "accent": {
      "type": "enumeration",
      "enum": ["navy", "paper", "paper-warm", "navy-deep"],
      "default": "paper"
    },
    "cta": {
      "type": "component",
      "repeatable": false,
      "component": "shared.cta-button"
    },
    "projectsRow": {
      "type": "component",
      "repeatable": true,
      "component": "shared.project-mini"
    }
  }
}
