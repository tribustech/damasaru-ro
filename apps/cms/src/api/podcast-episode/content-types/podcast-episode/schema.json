{
  "kind": "collectionType",
  "collectionName": "podcast_episodes",
  "info": {
    "singularName": "podcast-episode",
    "pluralName": "podcast-episodes",
    "displayName": "Podcast Episode"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "i18n": { "localized": true }
  },
  "attributes": {
    "number": {
      "type": "integer",
      "required": true
    },
    "title": {
      "pluginOptions": { "i18n": { "localized": true } },
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "description": {
      "pluginOptions": { "i18n": { "localized": true } },
      "type": "text"
    },
    "showNotes": {
      "pluginOptions": { "i18n": { "localized": true } },
      "type": "richtext"
    },
    "audioUrl": { "type": "string" },
    "videoUrl": { "type": "string" },
    "duration": { "type": "string" },
    "season": { "type": "integer", "default": 1 },
    "publishedAt2": { "type": "datetime" },
    "coverImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "guests": { "type": "json" },
    "featured": { "type": "boolean", "default": false }
  }
}
