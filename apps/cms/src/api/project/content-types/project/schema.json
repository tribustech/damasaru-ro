{
  "kind": "collectionType",
  "collectionName": "projects",
  "info": {
    "singularName": "project",
    "pluralName": "projects",
    "displayName": "Project"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "i18n": { "localized": true }
  },
  "attributes": {
    "name": {
      "pluginOptions": { "i18n": { "localized": true } },
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "tagline": {
      "pluginOptions": { "i18n": { "localized": true } },
      "type": "string"
    },
    "description": {
      "pluginOptions": { "i18n": { "localized": true } },
      "type": "text"
    },
    "manifesto": {
      "pluginOptions": { "i18n": { "localized": true } },
      "type": "richtext"
    },
    "heroImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "galleryImages": {
      "type": "media",
      "multiple": true,
      "allowedTypes": ["images"]
    },
    "externalUrl": { "type": "string" },
    "projectStatus": {
      "type": "enumeration",
      "enum": ["live", "upcoming", "archived"],
      "default": "live",
      "required": true
    },
    "accent": {
      "type": "enumeration",
      "enum": ["navy", "paper", "paper-warm", "navy-deep"],
      "default": "paper"
    },
    "order": { "type": "integer", "default": 0 }
  }
}
